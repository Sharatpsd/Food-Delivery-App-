# Bite backend environment template
# Copy this file to .env for local development and fill in real values.
# Do not commit your real .env file.

# ============================================================================
# Django core
# ============================================================================
# Generate a secret key with one of these commands:
# Python: python -c "from django.core.management.utils import get_random_secret_key; print(get_random_secret_key())"
# OpenSSL: openssl rand -base64 32
SECRET_KEY=replace-me-with-a-long-random-secret-key

# Local development should stay True.
# Set DEBUG=False in Render/production.
DEBUG=True

# Comma-separated hostnames only, no protocol.
ALLOWED_HOSTS=127.0.0.1,localhost,food-delivery-app-1-ihcm.onrender.com,.onrender.com

# ============================================================================
# Database
# ============================================================================
# Leave empty for local SQLite, or set a full Postgres URL.
# Example:
# DATABASE_URL=postgres://username:password@host:5432/database_name
DATABASE_URL=

# ============================================================================
# Google authentication
# ============================================================================
GOOGLE_CLIENT_ID=your-google-client-id.apps.googleusercontent.com

# Comma-separated list. Keep the first value the same as GOOGLE_CLIENT_ID
# unless you intentionally support multiple Google client IDs.
GOOGLE_CLIENT_IDS=your-google-client-id.apps.googleusercontent.com,optional-second-client-id.apps.googleusercontent.com

# ============================================================================
# Cloudinary media storage
# ============================================================================
CLOUDINARY_CLOUD_NAME=your-cloud-name
CLOUDINARY_API_KEY=your-cloudinary-api-key
CLOUDINARY_API_SECRET=your-cloudinary-api-secret

# ============================================================================
# Frontend / browser origins
# ============================================================================
# Frontend base URL used by payment and redirect flows.
FRONTEND_BASE_URL=http://localhost:5173

# Comma-separated browser origins with protocol.
CORS_ALLOWED_ORIGINS=http://localhost:5173,http://localhost:5174,http://127.0.0.1:5174,https://food-delivery-frontend-mktt.onrender.com,https://food-delivery-app-1-ihcm.onrender.com
CSRF_TRUSTED_ORIGINS=http://localhost:5173,http://localhost:5174,http://127.0.0.1:5174,https://food-delivery-frontend-mktt.onrender.com,https://food-delivery-app-1-ihcm.onrender.com

# ============================================================================
# SSLCommerz payments
# ============================================================================
SSLCOMMERZ_STORE_ID=
SSLCOMMERZ_STORE_PASSWORD=
SSLCOMMERZ_IS_SANDBOX=True
